function calcCardRarity(card){
  let score=0;
  if(card.packPct>=100)score+=40;else if(card.packPct>=80)score+=25;else if(card.packPct>=50)score+=12;
  if(card.budget>=80000)score+=20;else if(card.budget>=40000)score+=10;
  if(card.diagnosisScore>=90)score+=30;else if(card.diagnosisScore>=70)score+=15;else if(card.diagnosisScore>=50)score+=8;
  if(VENUES.some(v=>v.name===card.venue))score+=5;
  if(score>=90)return CARD_RARITIES[4];if(score>=65)return CARD_RARITIES[3];if(score>=40)return CARD_RARITIES[2];if(score>=20)return CARD_RARITIES[1];return CARD_RARITIES[0];
}

function drawTradingCard(card){
  const scale=2;const W=252*scale;const H=352*scale;
  const canvas=document.createElement('canvas');canvas.width=W;canvas.height=H;
  const ctx=canvas.getContext('2d');
  const acc=card.accentColor||state.accentColor;
  const rarity=card.rarity||calcCardRarity(card);
  const bg=ctx.createLinearGradient(0,0,0,H);bg.addColorStop(0,'#0d0d14');bg.addColorStop(1,'#1a1a2e');
  ctx.fillStyle=bg;ctx.fillRect(0,0,W,H);
  if(rarity.glow){const g=ctx.createRadialGradient(W/2,H*0.25,0,W/2,H*0.25,W*0.6);g.addColorStop(0,acc+'55');g.addColorStop(1,'transparent');ctx.fillStyle=g;ctx.fillRect(0,0,W,H);}
  const brd=ctx.createLinearGradient(0,0,W,H);brd.addColorStop(0,acc+'cc');brd.addColorStop(0.5,rarity.color+'cc');brd.addColorStop(1,acc+'cc');
  ctx.strokeStyle=brd;ctx.lineWidth=scale*1.5;ctx.beginPath();ctx.roundRect(scale,scale,W-scale*2,H-scale*2,12*scale);ctx.stroke();
  ctx.strokeStyle=acc+'22';ctx.lineWidth=scale*0.5;ctx.beginPath();ctx.roundRect(scale*4,scale*4,W-scale*8,H-scale*8,8*scale);ctx.stroke();
  const starY=18*scale;const starSpacing=14*scale;const startX=W/2-(rarity.starCount-1)*starSpacing/2;
  ctx.fillStyle=rarity.color;ctx.font=`${12*scale}px serif`;ctx.textAlign='center';
  for(let i=0;i<rarity.starCount;i++){ctx.fillText('★',startX+i*starSpacing,starY+4*scale);}
  ctx.font=`${6*scale}px 'DM Mono', monospace`;ctx.fillStyle=acc+'99';ctx.textAlign='center';ctx.fillText('ENSEI PASS',W/2,230);
  ctx.font=`${8*scale}px 'DM Mono', monospace`;ctx.fillStyle=rarity.color;ctx.textAlign='center';ctx.fillText(rarity.label,W/2,285);
  const vname=card.venue||'会場';const lines=vname.length>8?[vname.slice(0,8),vname.slice(8,16)]:[vname];
  ctx.font=`300 ${18*scale}px 'Noto Serif JP', serif`;ctx.fillStyle='rgba(255,255,255,0.95)';ctx.textAlign='center';
  if(rarity.glow){ctx.shadowColor=acc;ctx.shadowBlur=8*scale;}
  lines.forEach((line,i)=>ctx.fillText(line,W/2,(90+i*22)*scale));ctx.shadowBlur=0;
  ctx.strokeStyle=acc+'44';ctx.lineWidth=scale*0.5;
  ctx.beginPath();ctx.moveTo(20*scale,(90+lines.length*22+6)*scale);ctx.lineTo(W-20*scale,(90+lines.length*22+6)*scale);ctx.stroke();
  const statsY=(90+lines.length*22+18)*scale;
  const stats=[['推し色',card.colorName||state.colorName],['予算','¥'+(card.budget||state.budget).toLocaleString()],['パック',card.packPct+'%'],['戦闘力',card.diagnosisScore?card.diagnosisScore+'pt':'—']];
  stats.forEach(([k,v],i)=>{
    const y=statsY+i*14*scale;
    ctx.font=`${6.5*scale}px 'DM Mono', monospace`;ctx.fillStyle='rgba(255,255,255,0.4)';ctx.textAlign='left';ctx.fillText(k,22*scale,y);
    ctx.fillStyle='rgba(255,255,255,0.9)';ctx.textAlign='right';ctx.fillText(v,(W-22*scale),y);
  });
  ctx.save();ctx.shadowColor=acc;ctx.shadowBlur=12*scale;ctx.beginPath();ctx.arc(W/2,H-16*scale,4*scale,0,Math.PI*2);ctx.fillStyle=acc;ctx.fill();ctx.restore();
  const d=new Date(card.createdAt||Date.now()).toLocaleDateString('ja-JP',{year:'numeric',month:'2-digit',day:'2-digit'});
  ctx.font=`${5*scale}px 'DM Mono', monospace`;ctx.fillStyle='rgba(255,255,255,0.2)';ctx.textAlign='center';ctx.fillText(d,W/2,H-7*scale);
  return canvas;
}

function mintCurrentCard(){
  const all=Object.values(packItems).flat();
  const done=all.filter(i=>state.checks[i.id]).length;
  const pct=Math.round(done/all.length*100);
  const card={id:Date.now(),venue:state.venue,colorName:state.colorName,accentColor:state.accentColor,budget:state.budget,packPct:pct,diagnosisScore:state.lastDiagnosis?state.lastDiagnosis.score:0,createdAt:Date.now()};
  card.rarity=calcCardRarity(card);
  state.cards.unshift(card);saveState();renderCardCollection();
  showToast(`✦ ${card.rarity.label}カードをミントしました！`);
  if(card.rarity.label==='SSR'||card.rarity.label==='UR')launchConfetti();
}
function mintHistoryCards(){
  const sampleVenues=['東京ドーム','横浜アリーナ','さいたまスーパーアリーナ','マリンメッセ福岡','京セラドーム大阪'];
  const colors=[{name:'ピンク',color:'#E8547A'},{name:'ブルー',color:'#5B8CDB'},{name:'パープル',color:'#9B6AD4'}];
  for(let i=0;i<3;i++){
    const c=colors[i%colors.length];
    const card={id:Date.now()+i,venue:sampleVenues[i%sampleVenues.length],colorName:c.name,accentColor:c.color,budget:Math.round((20000+Math.random()*80000)/1000)*1000,packPct:Math.round(60+Math.random()*40),diagnosisScore:Math.round(50+Math.random()*50),createdAt:Date.now()-i*86400000*7};
    card.rarity=calcCardRarity(card);state.cards.push(card);
  }
  saveState();renderCardCollection();showToast('✦ 3枚のカードを生成しました');
}
function renderCardCollection(){
  const grid=document.getElementById('cardGrid');const empty=document.getElementById('collectionEmpty');if(!grid)return;
