/* ════════════════════════════════════════
   WEATHER (Phase 4 — Open-Meteo)
════════════════════════════════════════ */
function getWeatherAdvice(wmo,rain,temp){
  const a=[];
  if([61,63,65,80,81,82,95,96,99].includes(wmo))a.push('☂ 傘・レインコート必須');
  if([51,53,55].includes(wmo))a.push('☂ 折りたたみ傘があると安心');
  if(temp>=30)a.push('🌡 高温対策・ハンディファン必須');
  if(temp<=5)a.push('🧥 防寒具・カイロ必須');
  if(rain>=50)a.push('💧 撥水スプレーを前日から');
  return a.length?a.join(' / '):'✦ 天候は良好。遠征日和です！';
}

async function fetchWeather(){
  const dateVal=document.getElementById('weatherDate').value;
  if(!dateVal){showToast('遠征日を選択してください');return;}
  state.weatherDate=dateVal;
  const venue=VENUES.find(v=>v.name===state.venue)||VENUES[0];
  const lat=venue.lat||35.8948;const lon=venue.lon||139.6311;
  const panel=document.getElementById('weatherPanel');
  if(!panel)return;
  panel.innerHTML='<div style="padding:32px;text-align:center;color:var(--mt);font-size:13px;">天気情報を取得中...</div>';
  try{
    const url=`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=temperature_2m_max,temperature_2m_min,weathercode,precipitation_probability_max,windspeed_10m_max&hourly=temperature_2m,weathercode,precipitation_probability&timezone=Asia%2FTokyo&start_date=${dateVal}&end_date=${dateVal}`;
    const res=await fetch(url);const data=await res.json();
    const daily=data.daily;const hourly=data.hourly;
    const wmo_code=daily.weathercode[0];
    const tmax=Math.round(daily.temperature_2m_max[0]);
    const tmin=Math.round(daily.temperature_2m_min[0]);
    const rainPct=daily.precipitation_probability_max[0];
    const wind=Math.round(daily.windspeed_10m_max[0]);
    const wi=WMO[wmo_code]||{icon:'🌡',label:'情報なし'};
    const advice=getWeatherAdvice(wmo_code,rainPct,tmax);
    // Update pack alert
    const al=document.getElementById('weatherPackAlert');
    if(al){if(rainPct>=50||tmax>=30||tmax<=5){al.textContent='⚠ 天気情報アラート: '+advice;al.classList.remove('hidden');}else{al.classList.add('hidden');}}
    const hoursToShow=[10,12,14,16,18,19,20,21,22];
    const hourlyHTML=hoursToShow.map(h=>{
      const idx=hourly.time.findIndex(t=>t.includes(`T${String(h).padStart(2,'0')}:00`));
      if(idx<0)return'';
      const hw=WMO[hourly.weathercode[idx]]||{icon:'🌡'};
      const ht=Math.round(hourly.temperature_2m[idx]);
      const hp=hourly.precipitation_probability[idx];
      const isPeak=(h>=17&&h<=21);
      return`<div class="whr${isPeak?' pk':''}"><div style="font-size:9px;font-family:var(--fm);color:var(--mt);">${h}時</div><div style="font-size:18px;margin:4px 0;">${hw.icon}</div><div style="font-size:12px;font-family:var(--fm);">${ht}°</div><div style="font-size:9px;color:var(--mt);font-family:var(--fm);">${hp}%</div></div>`;
    }).join('');
    panel.innerHTML=`<div class="card"><div style="font-size:11px;font-family:var(--fm);color:var(--mt);letter-spacing:0.1em;margin-bottom:12px;">${venue.name} — ${dateVal}</div><div class="wbig"><div class="wicon">${wi.icon}</div><div><div class="wtemp">${tmax}<sup>°</sup></div><div style="font-size:13px;color:var(--mt);margin-top:2px;">${wi.label}（最低 ${tmin}°）</div><div style="font-size:11px;color:var(--accent-text);margin-top:4px;font-family:var(--fm);">${advice}</div></div></div><div class="wgrid"><div class="wcell"><div class="wcl">降水確率</div><div class="wcv">${rainPct}%</div></div><div class="wcell"><div class="wcl">最高気温</div><div class="wcv">${tmax}°</div></div><div class="wcell"><div class="wcl">最低気温</div><div class="wcv">${tmin}°</div></div><div class="wcell"><div class="wcl">風速</div><div class="wcv">${wind}m/s</div></div></div><div style="font-size:10px;font-family:var(--fm);color:var(--mt);margin:10px 0 4px;letter-spacing:0.1em;">時間別（開演前後）</div><div class="whrly">${hourlyHTML}</div></div>`;
    showToast('天気情報を取得しました');
  }catch(err){panel.innerHTML='<div style="padding:24px;text-align:center;font-size:13px;color:var(--mt);">天気情報の取得に失敗しました。日付を変えてお試しください。</div>';}
}

