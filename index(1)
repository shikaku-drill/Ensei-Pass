function buildJapanMap(){
  const wrap=document.getElementById('japanMapWrap');if(!wrap)return;
  const ns='http://www.w3.org/2000/svg';
  const svg=document.createElementNS(ns,'svg');
  svg.setAttribute('viewBox','0 0 800 760');
  svg.setAttribute('role','img');
  svg.setAttribute('aria-label','日本地図。各都道府県をタップして遠征記録を登録できます');
  const line=document.createElementNS(ns,'line');
  line.setAttribute('x1','227');line.setAttribute('y1','620');
  line.setAttribute('x2','227');line.setAttribute('y2','668');
  line.setAttribute('stroke','rgba(255,255,255,0.1)');line.setAttribute('stroke-width','1');
  line.setAttribute('stroke-dasharray','4,3');
  svg.appendChild(line);
  PREF_LAYOUT.forEach(([id,name,cx,cy,w,h])=>{
    const g=document.createElementNS(ns,'g');
