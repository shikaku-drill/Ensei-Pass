function downloadCard(id){const card=state.cards.find(c=>c.id===id);if(!card)return;const canvas=drawTradingCard(card);const a=document.createElement('a');a.download=`enseipass_card_${card.venue.slice(0,8)}_${card.rarity.label}.png`;a.href=canvas.toDataURL('image/png');a.click();showToast('カードを保存しました');}
