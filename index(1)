function splitText(text,maxLen){if(text.length<=maxLen)return[text];const mid=Math.ceil(text.length/2);return[text.slice(0,mid),text.slice(mid)];}

function renderStory(){
  const canvas=document.getElementById('storyCanvas');if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=1080;const H=1920;canvas.width=W;canvas.height=H;
  const theme=THEMES[state.theme]||THEMES.modern;
  const acc=state.accentColor;const opts=state.storyOpts;
  const all=Object.values(packItems).flat();
  const done=all.filter(i=>state.checks[i.id]).length;
  const pct=all.length?Math.round(done/all.length*100):0;
  const transportLabel={shinkansen:'新幹線',bus:'高速バス',flight:'飛行機',nightbus:'夜行バス'}[state.transport]||'';
  theme.bg(ctx,W,H,acc);
  function drawText(text,x,y,size,color,align='center',glow=false){ctx.save();if(glow&&opts.showGlow){ctx.shadowColor=acc;ctx.shadowBlur=30;}ctx.font=`300 ${size}px '${theme.font||'Noto Serif JP'}', serif`;ctx.fillStyle=color;ctx.textAlign=align;ctx.textBaseline='middle';ctx.fillText(text,x,y);ctx.restore();}
  function drawMono(text,x,y,size,color,align='center'){ctx.save();ctx.font=`300 ${size}px 'DM Mono', monospace`;ctx.fillStyle=color;ctx.textAlign=align;ctx.textBaseline='middle';ctx.fillText(text,x,y);ctx.restore();}
  const tc=theme.textColor||'#f0f0f8';const mc=theme.mutedColor||'rgba(255,255,255,0.5)';
  if(state.theme==='modern'||state.theme==='jirai'){ctx.save();ctx.shadowColor=acc;ctx.shadowBlur=40;ctx.beginPath();ctx.arc(W/2,160,14,0,Math.PI*2);ctx.fillStyle=acc;ctx.fill();ctx.restore();}
  drawMono('ENSEI PASS',W/2,230,32,mc+'cc');drawMono('COMPLETE',W/2,285,22,acc);
  ctx.strokeStyle=acc+'66';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(W/2-140,320);ctx.lineTo(W/2+140,320);ctx.stroke();
  const venueLines=splitText(state.venue,18);let vy=420;
  drawText('会場',W/2,360,28,mc);
  venueLines.forEach(line=>{drawText(line,W/2,vy,68,tc,'center',true);vy+=90;});
  const infoY=Math.max(vy+60,700);const infos=[];
  if(opts.showBudget)infos.push({label:'遠征予算',val:'¥'+state.budget.toLocaleString()});
  infos.push({label:'推し色',val:state.colorName});
  if(opts.showTransport&&transportLabel)infos.push({label:'交通',val:transportLabel});
  if(opts.showPack)infos.push({label:'パック進捗',val:pct+'%'});
  infos.forEach((info,i)=>{const y=infoY+i*90;drawMono(info.label,180,y,26,mc,'left');drawText(info.val,W-180,y,42,tc,'right',info.label==='遠征予算');});
  const midY=infoY+infos.length*90+60;
  ctx.strokeStyle=acc+'33';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(60,midY);ctx.lineTo(W-60,midY);ctx.stroke();
  if(opts.showPack){
    const pbY=midY+60;drawMono('PACKING PROGRESS',W/2,pbY,24,mc);
    const pbW=W-160,pbX=80;
    ctx.fillStyle='rgba(255,255,255,0.08)';ctx.beginPath();ctx.roundRect(pbX,pbY+30,pbW,12,6);ctx.fill();
    if(pct>0){const grad=ctx.createLinearGradient(pbX,0,pbX+pbW*(pct/100),0);grad.addColorStop(0,acc+'99');grad.addColorStop(1,acc);ctx.save();if(opts.showGlow){ctx.shadowColor=acc;ctx.shadowBlur=12;}ctx.fillStyle=grad;ctx.beginPath();ctx.roundRect(pbX,pbY+30,pbW*(pct/100),12,6);ctx.fill();ctx.restore();}
    drawMono(pct+'% READY',W/2,pbY+80,36,tc);
  }
  const botY=H-120;ctx.strokeStyle=acc+'22';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(60,botY-30);ctx.lineTo(W-60,botY-30);ctx.stroke();
  drawMono('ENSEI PASS — 準備さえも、推し事になる',W/2,botY,22,mc+'88');
  ctx.save();ctx.shadowColor=acc;ctx.shadowBlur=20;ctx.beginPath();ctx.arc(W/2,botY+60,6,0,Math.PI*2);ctx.fillStyle=acc;ctx.fill();ctx.restore();
}
function downloadStory(){renderStory();const canvas=document.getElementById('storyCanvas');const a=document.createElement('a');a.download=`enseipass_${state.venue}_${state.theme}.png`;a.href=canvas.toDataURL('image/png');a.click();showToast('ストーリー画像を保存しました');}
