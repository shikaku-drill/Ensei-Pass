    rect.addEventListener('keydown',(e)=>{if(e.key==='Enter'||e.key===' ')togglePref(id,name);});
    g.appendChild(rect);g.appendChild(txt);svg.appendChild(g);
  });
  wrap.innerHTML='';wrap.appendChild(svg);
  updateMapColors();
}

function togglePref(id,name){
  if(state.homePrefs.has(name)){state.homePrefs.delete(name);state.visitedPrefs.add(name);}
  else if(state.visitedPrefs.has(name)){state.visitedPrefs.delete(name);}
  else{state.visitedPrefs.add(name);}
  updateMapColors();updateMapStats();saveState();
  showToast(state.visitedPrefs.has(name)?`✦ ${name} を遠征済みに追加`:`${name} を解除しました`);
}
function toggleHomePref(id,name){
  if(state.homePrefs.has(name)){state.homePrefs.delete(name);}
  else{state.visitedPrefs.delete(name);state.homePrefs.add(name);}
  updateMapColors();updateMapStats();saveState();
