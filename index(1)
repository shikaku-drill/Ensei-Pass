    wrap.appendChild(actions);
    const rLabel=document.createElement('div');rLabel.style.cssText='text-align:center;font-family:var(--fm);font-size:9px;letter-spacing:0.12em;margin-top:4px;';rLabel.style.color=card.rarity.color;rLabel.textContent=card.rarity.label+' — '+card.venue.slice(0,12);
    wrap.appendChild(rLabel);
