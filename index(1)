function loadState(){
  try{
    const s=JSON.parse(localStorage.getItem(LS_KEY)||'null');
    if(!s)return;
    Object.assign(state,s);
    state.visitedPrefs=new Set(s.visitedPrefs||[]);
    state.homePrefs=new Set(s.homePrefs||[]);
    state.expeditionHistory=s.expeditionHistory||[];
    state.cards=s.cards||[];
    applyAccent(state.accentColor,state.accentRgb,state.accentText,state.accentLight,state.colorName,state.auraA,state.auraB,true);
    document.getElementById('venueInput').value=state.venue;
    document.getElementById('budgetInput').value=state.budget;
    onBudgetChange();updateSummaryVenue();
    const found=VENUES.find(v=>v.name===state.venue);
    if(found){renderVenueInfo(found);}
    buildVenueLinks(state.venue);
    if(state.lastDiagnosis)document.getElementById('summaryPower').textContent=`${state.lastDiagnosis.rank} (${state.lastDiagnosis.score})`;
    if(state.restoreCode)displayRestoreCode(state.restoreCode);
    if(state.theme){document.querySelectorAll('.thbtn').forEach(b=>{b.classList.toggle('active',b.dataset.theme===state.theme);});}
    // Restore hotel status
    if(state.hotelStatus==='last')setHotelStatus('last');
    // Restore transport
    switchTransport(state.transport,true);
    // Restore dist buttons
    document.querySelectorAll('.db').forEach(b=>{
      const d=b.onclick?b.getAttribute('onclick')||'':b.outerHTML;
